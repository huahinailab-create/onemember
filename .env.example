APP_NAME=OneMember
APP_ENV=local          # Set to "production" on server
APP_KEY=               # Generate with: php artisan key:generate
APP_DEBUG=true         # Set to false in production
APP_URL=https://app.onemember.co
APP_VERSION=1.0

# ── Domain Routing (DECISION-065) ──────────────────────────────────────────
# Corporate website: https://onemember.co  and  https://www.onemember.co
# Merchant app:      https://app.onemember.co
#
# Local development: add to /etc/hosts:
#   127.0.0.1  onemember.local
#   127.0.0.1  www.onemember.local
#   127.0.0.1  app.onemember.local
# Then set these to *.local equivalents and use Laravel Valet or php artisan serve.
CORPORATE_DOMAIN=onemember.co
CORPORATE_WWW_DOMAIN=www.onemember.co
APP_DOMAIN=app.onemember.co

APP_LOCALE=th
APP_FALLBACK_LOCALE=th
APP_FAKER_LOCALE=th_TH

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.onemember.co  # Dot prefix shares session across all subdomains (required for domain routing)
SESSION_SECURE_COOKIE=false  # Set to true in production (HTTPS required)
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — use "log" locally, "resend" in production
# Get RESEND_API_KEY from resend.com/api-keys (domain no-reply@onemember.co must be verified)
MAIL_MAILER=log
RESEND_API_KEY=
MAIL_FROM_ADDRESS="no-reply@onemember.co"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO=
SUPPORT_EMAIL="support@onemember.co"
SALES_EMAIL="sales@onemember.co"
HELLO_EMAIL="hello@onemember.co"
PRIVACY_EMAIL="privacy@onemember.co"
SECURITY_EMAIL="security@onemember.co"
EMAIL_LOGO_URL=
EMAIL_COMPANY_NAME="${APP_NAME}"
EMAIL_FOOTER_TEXT=
EMAIL_SOCIAL_TWITTER=
EMAIL_SOCIAL_FACEBOOK=
EMAIL_SOCIAL_LINKEDIN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Backup verification (backup:verify command)
BACKUP_PATH=/var/backups/onemember  # Directory where mysqldump writes db_*.sql.gz files

# Stripe Billing
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CURRENCY=thb
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_

# Developer Tools
# Set to true on local/staging to enable the /dev route group.
# NEVER set to true in production.
DEV_TOOLS_ENABLED=false

# Analytics & Feedback
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=null        # Options: null, posthog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_TIMEOUT=2
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
ANALYTICS_TRACK_PAGE_VIEWS=true
ANALYTICS_TRACK_EVENTS=true
ANALYTICS_TRACK_EXCEPTIONS=true
ANALYTICS_IDENTIFY=true
